# VERTEX RD — local / deploy secrets (copy to .env)
# Never commit .env

# Required — Mapbox public token (restrict by URL in Mapbox dashboard)
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# Optional — PostGIS (defaults to SQLite fallback if unavailable)
# DATABASE_URL=postgresql://vertex:vertex123@localhost:5432/vertex_rd

# Optional — path to VERTEXRD shapefiles when running export scripts
# VERTEX_ROOT=..
